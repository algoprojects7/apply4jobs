datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id          String    @id @default(uuid())
  name        String
  domain      String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  companies   Company[]
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]
  users       User[]
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique
  roles       Role[]
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  passwordHash    String
  phoneNumber     String?
  isVerified      Boolean           @default(false)
  mfaSecret       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  tenantId        String?
  tenant          Tenant?           @relation(fields: [tenantId], references: [id])
  roleId          String
  role            Role              @relation(fields: [roleId], references: [id])
  sessions        Session[]
  candidateProfile CandidateProfile?
  companyUsers    CompanyUser[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Company {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  name        String
  logoUrl     String?
  website     String?
  description String?
  isVerified  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       CompanyUser[]
  jobs        Job[]
}

model CompanyUser {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Job {
  id              String           @id @default(uuid())
  companyId       String
  company         Company          @relation(fields: [companyId], references: [id])
  title           String
  description     String
  status          String           @default("Draft") // Draft, Review, Published, Closed, Archived
  salaryMin       Int?
  salaryMax       Int?
  experienceMin   Int?
  experienceMax   Int?
  employmentType  String?          // Full-time, Part-time, Contract, Internship
  remoteType      String?          // Onsite, Hybrid, Remote
  skillsRequired  String[]
  location        String?
  vacancyCount    Int              @default(1)
  deadline        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    JobApplication[]
  savedByCandidates SavedJob[]
  recommendations RecommendationScore[]
}

model CandidateProfile {
  id             String                @id @default(uuid())
  userId         String                @unique
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  gender         String?               // Male, Female, Non-binary, Prefer not to say
  avatarUrl      String?
  portfolioUrl   String?
  profileScore   Int                   @default(0)
  skills         String[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  experiences    CandidateExperience[]
  educations     CandidateEducation[]
  resumes        Resume[]
  applications   JobApplication[]
  savedJobs      SavedJob[]
  searchHistories SearchHistory[]
  recommendations RecommendationScore[]
  behaviors      BehavioralPattern[]
}

model CandidateExperience {
  id          String           @id @default(uuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  companyName String
  title       String
  startDate   DateTime
  endDate     DateTime?
  description String?
}

model CandidateEducation {
  id           String           @id @default(uuid())
  profileId    String
  profile      CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institution  String
  degree       String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?
}

model Resume {
  id          String          @id @default(uuid())
  profileId   String
  profile     CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileUrl     String
  parsedText  String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  analysis    ResumeAnalysis?
}

model ResumeAnalysis {
  id              String   @id @default(uuid())
  resumeId        String   @unique
  resume          Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  atsScore        Int
  qualityScore    Int
  extractedSkills String[]
  improvements    Json?    // Suggestions matrix JSON
  suggestedRoles  String[]
  createdAt       DateTime @default(now())
}

model JobApplication {
  id          String           @id @default(uuid())
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id])
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  status      String           @default("Applied") // Applied, Shortlisted, Assessment, Interview, Selected, Offered, Hired, Rejected
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  interviews  Interview[]
}

model Interview {
  id            String         @id @default(uuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id])
  scheduledAt   DateTime
  meetingLink   String?
  feedback      String?
  createdAt     DateTime       @default(now())
}

model SavedJob {
  id          String           @id @default(uuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id])
  createdAt   DateTime         @default(now())
}

model SearchHistory {
  id          String           @id @default(uuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  query       String
  filters     Json?
  createdAt   DateTime         @default(now())
}

model RecommendationScore {
  id          String           @id @default(uuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  jobId       String
  job         Job              @relation(fields: [jobId], references: [id])
  score       Float
  reason      String?
  createdAt   DateTime         @default(now())
}

model BehavioralPattern {
  id          String           @id @default(uuid())
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id])
  patternType String
  confidence  Float
  createdAt   DateTime         @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
