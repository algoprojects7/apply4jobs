{
  "name": "leadhire-ai-monorepo",
  "version": "1.0.0",
  "description": "LeadHire AI Multi-Tenant SaaS Job Marketplace",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @leadhire/api start:dev",
    "dev:web": "pnpm --filter @leadhire/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "start:api": "pnpm --filter @leadhire/api start",
    "start:web": "pnpm --filter @leadhire/web start",
    "db:generate": "pnpm --filter @leadhire/database db:generate",
    "db:migrate": "pnpm --filter @leadhire/database db:migrate"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ]
  }
}
